# Frontend env (Vite). Copy to web/.env.local for overrides. No secrets here — the SPA never holds
# provider API keys (root Key safety rules; only the ephemeral Realtime credential reaches the browser).

# Base URL for the backend API + cascade WS (ARCH-029).
# Leave EMPTY in dev to use the Vite dev proxy (/api -> http://localhost:5179, relative paths).
# Set to a full origin (e.g. http://localhost:5179) for direct mode against the backend's CORS-allowed origin.
VITE_API_BASE_URL=
