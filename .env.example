# AI Interpreter Workbench — environment configuration (ARCH-028).
# Copy to `.env` and fill in the secret values. NEVER commit a real key.
# Standard provider keys are backend-only and never reach the browser (ARCH-019);
# the SPA receives only the short-lived ephemeral Realtime credential (ek_…).

# --- OpenAI (standard key — backend only, never to browser) ---
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime    # or gpt-realtime-mini
OPENAI_REALTIME_VOICE=alloy
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_TRANSLATION_MODEL=gpt-5.4-nano # or gpt-5.4-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_FORMAT=mp3

# --- Deepgram (standard key — backend only) ---
DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_STT_LANGUAGE=multi
DEEPGRAM_ENCODING=linear16
DEEPGRAM_SAMPLE_RATE=48000

# --- Per-stage timeouts (seconds) ---
STT_TIMEOUT_SECONDS=30
TRANSLATION_TIMEOUT_SECONDS=20
TTS_TIMEOUT_SECONDS=30
REALTIME_TOKEN_TIMEOUT_SECONDS=10

# --- Audio upload caps (C.5 cascade blob fallback / F.1b evaluation transcribe) ---
CASCADE_MAX_UPLOAD_BYTES=10485760     # upload cap (~10MB); bounds the validator (413) + the multipart/Kestrel body limit
EVAL_MAX_UPLOAD_BYTES=10485760        # evaluation transcribe cap; optional — falls back to CASCADE_MAX_UPLOAD_BYTES. Body-limit backstop = max(cascade, eval).

# --- Paths (relative to server/AiInterpreter.Api/) ---
SESSION_DATA_DIR=../../data/sessions
PRICING_CONFIG_PATH=../../config/pricing.json
# Scripted WER phrases (ARCH-015). Defaults to the content file shipped next to the host; override only to point elsewhere.
EVALUATION_PHRASES_PATH=

# --- Host ---
ASPNETCORE_ENVIRONMENT=Development
